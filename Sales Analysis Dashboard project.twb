  <worksheets>
    <worksheet name='Avg Profit  by States (2)'>
      <table>
        <view>
          <datasources>
            <datasource caption='Orders+ (Sales Data)' name='federated.0etjity19ju87y19qncp217k6gx5' />
          </datasources>
          <datasource-dependencies datasource='federated.0etjity19ju87y19qncp217k6gx5'>
            <column caption='Avg Profit Overall ' datatype='real' name='[Avg Sales Overall (copy)_0874442676793352]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED : AVG(IF YEAR([Order Date]) = {MAX(YEAR([Order Date]))} THEN [Total CY Sales (copy)_1067681608687621] END)}' />
            </column>
            <column caption='Avg Profit State Wise ' datatype='real' name='[Avg Sales State W ise (copy)_0874442676981769]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [State/Province] : AVG([Total CY Sales (copy)_1067681608687621])}' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column aggregation='Sum' datatype='real' name='[Column]' role='dimension' type='ordinal' />
            <column datatype='date' name='[Order Date]' role='dimension' type='ordinal' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column datatype='string' name='[Region]' role='dimension' type='nominal' />
            <column aggregation='Sum' datatype='integer' name='[Row]' role='dimension' type='ordinal' />
            <column caption='Profit Avg Color ' datatype='string' name='[Sales Avg Color (copy)_0874442676617223]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Avg Sales State W ise (copy)_0874442676981769]&lt; [Avg Sales Overall (copy)_0874442676793352] THEN &quot;Below Average&quot;&#13;&#10;ELSEIF [Avg Sales State W ise (copy)_0874442676981769]&gt; [Avg Sales Overall (copy)_0874442676793352] THEN &quot;Above Average&quot;&#13;&#10;ELSEIF [Avg Sales State W ise (copy)_0874442676981769]= [Avg Sales Overall (copy)_0874442676793352] THEN &quot;Equal to Average&quot;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Ship Mode]' role='dimension' type='nominal' />
            <column datatype='string' name='[State/Province]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
